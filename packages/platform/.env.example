# =====================================================================
# AI Travel Planner — Platform environment template
# Location: copy to apps/api/.env when running uvicorn from apps/api/.
# Anything left blank falls back to a safe default in `app_platform.application_settings`.
# =====================================================================

# ---- Application ----------------------------------------------------
APP_ENV=development            # development | staging | production
APP_NAME=ai-travel-planner
APP_VERSION=0.1.0
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR
LOG_JSON=true                  # true = structured JSON logs, false = pretty console

# Mock mode short-circuits all external tool calls (web/maps/hotels/fx)
# and returns deterministic fixtures from tests/fixtures.
# Tests run with MOCK_MODE=true so no API keys are required.
MOCK_MODE=true

# ---- LLM providers (Phase 1+) --------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Default model selection
LLM_REASONING_MODEL=gpt-4o
LLM_CHEAP_MODEL=gpt-4o-mini

# ---- External tools (Phase 2+) -------------------------------------
TAVILY_API_KEY=                # web_search
SERPAPI_API_KEY=               # alternative web search
GOOGLE_MAPS_API_KEY=           # maps_distance
AMADEUS_API_KEY=               # hotels / transit
AMADEUS_API_SECRET=
RAPIDAPI_KEY=                  # fallback for hotels / transit
EXCHANGERATE_API_KEY=          # fx_convert

# ---- Memory / state (Phase 7+) -------------------------------------
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/travel_planner

# Vector DB (one of: qdrant | chroma | pinecone)
VECTOR_DB=chroma
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
PINECONE_API_KEY=
PINECONE_ENV=

# ---- Observability (Phase 9+) --------------------------------------
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ai-travel-planner
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ---- API server ----------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
# Allow the Next.js dev server (frontend/) to call the API
API_CORS_ORIGINS=http://localhost:3000
